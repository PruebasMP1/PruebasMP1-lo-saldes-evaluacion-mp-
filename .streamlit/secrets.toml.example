# PLANTILLA de secretos. NO pongas tus claves aquí.
# - En la NUBE: copia este contenido (relleno) en Streamlit Cloud → Settings → Secrets.
# - En tu PC (si quisieras probar Google Sheets local): copia este archivo como
#   "secrets.toml" (sin .example) y rellénalo. Ese archivo NO se sube (está en .gitignore).

# (Opcional) Contraseña para entrar a la app. Si la borras, la app queda abierta.
app_password = "cambia-esta-clave"

# --- Conexión a la planilla Google (repositorio persistente) ---
[gsheets]
spreadsheet_id = "PEGA_AQUI_EL_ID_DE_TU_PLANILLA"
worksheet = "evaluaciones"

# Credenciales de la "cuenta de servicio" de Google (las da Google Cloud, ver DEPLOY.md).
# Pega el contenido del archivo JSON que descargaste, campo por campo:
[gcp_service_account]
type = "service_account"
project_id = "..."
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "...@....iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
