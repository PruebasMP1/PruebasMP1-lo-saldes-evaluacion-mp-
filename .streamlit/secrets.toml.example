# PLANTILLA de secretos. NO pongas tus claves aquí.
# En la NUBE: copia lo de abajo (relleno) en Streamlit Cloud → Settings → Secrets.

# (Opcional) Contraseña para entrar a TODA la app. Si la borras, la app queda abierta
# (recomendado dejarla abierta para que producción cargue datos sin trabas).
# app_password = "cambia-esta-clave"

# Clave CORTA solo para la pestaña Dashboard (los números de gestión).
# Producción carga datos libre; el dashboard queda reservado para Control de Gestión.
dash_password = "1234"

# === OPCIÓN ELEGIDA: base de datos Neon (Postgres) ===
# Pega aquí el "Connection string" que te da Neon (empieza con postgresql://...).
# Con esto los datos y fotos se guardan permanente. Es lo ÚNICO obligatorio.
database_url = "postgresql://USUARIO:CLAVE@ep-xxxxx.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# --- (Alternativa, NO necesaria si usas Neon) planilla Google ---
# [gsheets]
# spreadsheet_id = "..."
# worksheet = "evaluaciones"
# [gcp_service_account]
# ... (credenciales del JSON de Google) ...
